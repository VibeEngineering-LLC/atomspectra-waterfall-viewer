# venv / Python
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Реальные данные спектрометра — НЕ в git (N42 может содержать GPS/метаданные устройства)
sample_data/*.n42
# Спектрограммы RadiaCode (.rcspg, JSON: deviceId/координаты/время) — тоже не в git
sample_data/*.rcspg
*.rcspg
# Нативные waterfall AtomSpectra (.aswf, заголовок: serial/IP-источник) — тоже не в git
sample_data/*.aswf
*.aswf

# Логи прогона (run.bat пишет stderr сюда)
*.log

# Сборка PyInstaller
build/
dist/
*.spec

# IDE / прочее
.vscode/
.idea/

# graphify — регенерируемая графовая карта проекта (graphify update .)
graphify-out/

# Кэш IAEA LiveChart (сырые ENSDF CSV, скачиваются по кнопке; офлайн-воспроизводимость) — не в git
awf/data/iaea_cache/
